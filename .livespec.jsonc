{
  "template": "livespec-with-diagrams",
  "spec_root": "SPECIFICATION",
  // Conformance profile(s) this governed repo satisfies — the LOCAL
  // declaration (mirroring the central fleet manifest), per
  // livespec/SPECIFICATION/non-functional-requirements.md §"Conformance
  // Pattern". `baseline` is the universal worktree-discipline floor: the
  // structural commit-refuse hook (installed via `just
  // install-commit-refuse-hooks`, REUSED from livespec-dev-tooling) plus its
  // verifier `just check-baseline`, wired into the `just check` aggregate.
  "profile": ["baseline"],
  // Declared agent-runtime harnesses for the Conformance Pattern's cross-harness
  // plugin-resolution concern (concern #2), read by livespec-dev-tooling's
  // check-plugin-resolution Verifier. This is the Rust Control-Plane console; it
  // ships no command/skill surface to resolve from a harness, so both are EXEMPT.
  "harnesses": {
    "claude": { "status": "exempt", "reason": "livespec-console-beads-fabro is the Rust Control-Plane console; it ships no command/skill surface to resolve from a harness" },
    "codex":  { "status": "exempt", "reason": "livespec-console-beads-fabro is the Rust Control-Plane console; it ships no command/skill surface to resolve from a harness" }
  },
  "implementation": { "plugin": "livespec-orchestrator-beads-fabro" },
  // Credential-injection wrapper (fleet default) prefixed to the beads CLIs so a bare invocation self-heals its tenant secret.
  "credential_wrapper": ["/usr/local/bin/with-livespec-env.sh", "--"],
  "livespec-orchestrator-beads-fabro": {
    "format": "beads",
    "compat": {
      "livespec": ">=0.1.0,<1.0.0",
      // Pinned to the latest livespec-core RELEASE tag, not the moving
      // `master` ref: a release is reproducible and carries release-gate
      // validation, per the fleet "pins track the latest RELEASE, not raw
      // master" discipline. Advanced off the `master` bootstrap placeholder
      // (which left CI hostage to core master's transient content); the
      // bump-pin fan-out rewrites this to each new release tag going forward.
      "pinned": "v0.20.1"
    },
    "connection": {
      "tenant": "livespec-console-beads-fabro",
      "prefix": "livespec-console-beads-fabro",
      "database": "livespec-console-beads-fabro",
      "server_user": "livespec-console-beads-fabro",
      "server_host": "127.0.0.1",
      "server_port": 3307,
      "fake": false
    },
    // Human-valve settings (restored 2026-07-21, plan/console-happy-path-mvp/).
    // The 2026-07-20 autonomous-mode levers (auto_approve_ready: true,
    // acceptance_mode: "ai-only") were maintainer-directed for the
    // autonomous-mode acceptance work; that mode is retired for good, and the
    // happy-path walk admits at the approve valve and ships at the accept
    // valve, so both levers are back at their safe defaults:
    //   auto_approve_ready: false          — a human admits at the valve.
    //   acceptance_mode: "ai-then-human"   — AI reviews, a human ships.
    // The third lever, `merge_on_review_cap`, stays at its safe `false`
    // default: a review that cannot converge within `review_fix_cap` rounds is
    // precisely the case that must reach a human. A design-human-gated
    // (spec-change-tier) item still cannot auto-approve regardless of these.
    //
    // EDIT THIS BLOCK BY HAND. Do NOT use `drive --action set-config:<k>:<v>`:
    // that surface round-trips the file through json.dumps and silently strips
    // every comment here while reporting green — tracked as bd-ib-lmi5.
    "dispatcher": {
      "auto_approve_ready": false,
      "acceptance_mode": "ai-then-human"
    }
  }
}

